#!/data/data/com.termux/files/usr/bin/bash
# Hub-Status — Quick health snapshot of the Pi (Anderson hub) via Tailscale.
# Speaks a short status summary.

PI_HOST="anderson-hub.tailf0f27a.ts.net"
PI_IP="100.123.152.77"

REPORT=""

# 1. Tailscale reachability
if curl -s -o /dev/null -w '%{http_code}' --max-time 5 "https://$PI_HOST/" | grep -q '200'; then
  REPORT+="Anderson hub alive. "
else
  REPORT+="Anderson hub not responding. "
  termux-tts-speak "$REPORT"
  exit 1
fi

# 2. SSH login + uptime
UPTIME=$(ssh -o ConnectTimeout=5 pi 'uptime -p' 2>/dev/null | sed 's/up //')
[ -n "$UPTIME" ] && REPORT+="Up $UPTIME. "

# 3. Recent reading count (use FT API endpoint if available; fallback to ssh)
READINGS=$(ssh -o ConnectTimeout=5 pi 'curl -s http://localhost:3001/health 2>/dev/null || echo {}' | python3 -c "
import sys,json
try:
    d=json.load(sys.stdin)
    if d.get('status')=='ok' or d.get('ok'): print('all services up')
    else: print('some services degraded')
except: print('health endpoint silent')
" 2>/dev/null)
[ -n "$READINGS" ] && REPORT+="$READINGS. "

termux-tts-speak "$REPORT"

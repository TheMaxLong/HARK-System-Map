#!/data/data/com.termux/files/usr/bin/bash
# FacilityCheck — Triggers Max's FacilityCheck audit on Mac via ntfy.
# Mac runs the 5-step sweep, SSHes back with TTS summary + notification.

TOPIC="hark-facility-check-b6d6f70e9913"

# Detect which phone we are (used so Mac knows where to send the result back)
DEVICE_MODEL=$(getprop ro.product.model 2>/dev/null)
case "$DEVICE_MODEL" in
  *"Pixel 10"*) PHONE=pixel10 ;;
  *"Pixel 6"*) PHONE=pixel6 ;;
  *) PHONE=pixel6 ;;  # default
esac

curl -s -X POST \
  -H "Title: FacilityCheck triggered" \
  -d "$PHONE" \
  "https://ntfy.sh/$TOPIC" > /dev/null

termux-vibrate -d 200
termux-tts-speak "Facility check started on Mac. I'll report when it's done."

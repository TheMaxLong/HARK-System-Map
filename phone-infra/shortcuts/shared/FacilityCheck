#!/data/data/com.termux/files/usr/bin/bash
# FacilityCheck — triggers Max's FacilityCheck sweep on the Mac via ntfy.
# The Mac listener runs the 5-step sweep and pushes the RESULT back on the
# gacx-recipe-tripwire ntfy topic (and the broken-pump detector posts there too).
TOPIC="hark-facility-check-b6d6f70e9913"

DEVICE_MODEL=$(getprop ro.product.model 2>/dev/null)
case "$DEVICE_MODEL" in
  *"Pixel 10"*) PHONE=pixel10 ;;
  *"Pixel 6"*)  PHONE=pixel6  ;;
  *)            PHONE=pixel10 ;;
esac

termux-vibrate -d 200 2>/dev/null

# Publish SYNCHRONOUSLY (foreground). The previous version backgrounded + disowned
# the curl then exited, and Termux:Widget reaps the process group on return — so
# the POST often never sent (the "does nothing" bug). A foreground curl finishes
# the POST before exit; it's sub-second and --max-time caps it well under ANR.
curl -s -X POST --connect-timeout 3 --max-time 8 \
  -H "Title: FacilityCheck triggered" \
  -d "$PHONE" \
  "https://ntfy.sh/$TOPIC" >/dev/null 2>&1

# Spoken confirmation, fully detached so it can't block the UI thread.
setsid sh -c 'termux-tts-speak "Facility check started. Result will come through." >/dev/null 2>&1' </dev/null >/dev/null 2>&1 &

exit 0

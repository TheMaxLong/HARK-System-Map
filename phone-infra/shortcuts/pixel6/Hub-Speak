#!/data/data/com.termux/files/usr/bin/bash
# Hub-Speak — Type or voice in something; Pixel 6 speaker announces it.

MSG=$(termux-speech-to-text 2>/dev/null)
if [ -z "$MSG" ] || [ "$MSG" = "}" ]; then
  MSG=$(termux-dialog text -t "Hub Speak" -i "Say what?" 2>/dev/null | python3 -c "import sys,json;print(json.load(sys.stdin).get('text',''))" 2>/dev/null)
fi
[ -z "$MSG" ] && { termux-tts-speak "Nothing to say."; exit 1; }

termux-tts-speak "$MSG"
